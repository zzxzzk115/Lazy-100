lazy-100 cartridge
version 1
__lua__
-- breakout.lz100 - Lazy-100 demo: sprite bricks/paddle/ball, map background,
-- sfx + a chained looping soundtrack. Arrows move, Z launches.
brows=5 bcols=13
bw=16 bh=12 bgx=56 bgy=40

function _init()
  px=140 score=0 lives=3
  new_bricks() reset_ball() music(0)
end

function new_bricks()
  bricks={} live=0
  for r=0,brows-1 do
    for c=0,bcols-1 do
      bricks[r*bcols+c]=true live=live+1
    end
  end
end

function reset_ball()
  launched=false
  bx=px+20 by=200 bvx=2 bvy=-2.5
end

function _update()
  if btn(0) then px=px-4 end
  if btn(1) then px=px+4 end
  px=mid(0,px,280)

  if not launched then
    bx=px+20
    if btnp(4) then launched=true end
    return
  end

  bx=bx+bvx by=by+bvy

  if bx<4 then bx=4 bvx=-bvx sfx(0) end
  if bx>316 then bx=316 bvx=-bvx sfx(0) end
  if by<12 then by=12 bvy=-bvy sfx(0) end

  if by>216 and by<230 and bx>px-4 and bx<px+44 then
    by=216 bvy=-abs(bvy)
    bvx=mid(-4, bvx+(bx-(px+20))/10, 4)
    sfx(1)
  end

  local hitb=false
  for r=0,brows-1 do
    for c=0,bcols-1 do
      local i=r*bcols+c
      if bricks[i] and not hitb then
        local x0=bgx+c*bw local y0=bgy+r*bh
        if bx>x0-2 and bx<x0+bw and by>y0-2 and by<y0+bh-1 then
          bricks[i]=false live=live-1 score=score+10
          bvy=-bvy hitb=true sfx(2)
        end
      end
    end
  end

  if by>244 then
    lives=lives-1 sfx(3)
    if lives<=0 then _init() else reset_ball() end
  end
  if live<=0 then new_bricks() reset_ball() end
end

function _draw()
  cls(0)
  map(0,0,0,0,20,15)            -- map background
  for r=0,brows-1 do
    pal(8,8+r)                  -- recolor the brick body per row
    for c=0,bcols-1 do
      if bricks[r*bcols+c] then
        spr(1, bgx+c*bw, bgy+r*bh)
      end
    end
  end
  pal()
  sspr(48,0,16,6, px,224, 44,8) -- paddle sprite stretched
  spr(2, bx-8, by-8)            -- ball sprite (centered)
  print("score "..score,6,2,7)
  print("lives "..lives,250,2,7)
  if not launched then print("z: launch   arrows: move",84,150,7) end
end
