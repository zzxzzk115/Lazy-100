// Windows resource script: link built-in assets into the executable as RCDATA.
// Compiled into the host binary target (see examples/xmake.lua). Paths are relative to
// this .rc file. Resource id 1001 = the font (see source/lazy100/vfs/embed.cpp).

1001 RCDATA "../assets/fonts/fusion-pixel-10px-monospaced-zh_hans.ttf"
